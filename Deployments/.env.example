# ============================================
# IoTSharp 生产环境密钥配置
# ============================================
# 此文件为示例，实际部署时复制为 .env 并填入真实值
# cp .env.example .env
#
# ⚠️  .env 文件绝不提交到版本库
# ============================================

# PostgreSQL
PG_PASSWORD=change_me_pg_password

# RabbitMQ
RABBITMQ_USER=iotsharp
RABBITMQ_PASSWORD=change_me_rabbitmq_password

# JWT (至少 32 个字符)
JWT_KEY=change_me_jwt_key_at_least_32_chars